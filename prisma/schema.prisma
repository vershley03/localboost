// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businesses    Business[]
  subscriptions Subscription[]
}

model Business {
  id           String   @id @default(cuid())
  userId       String
  name         String
  category     String
  country      String
  city         String
  description  String?
  website      String?
  instagramUrl String?
  brandColors  Json?     // {primary, secondary, accent}
  logoUrl      String?
  iconUrl      String?
  visualStyle  String?   @default("cozy_rustic")
  customStylePrompt String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user               User                @relation(fields: [userId], references: [id])
  brandProfile       BrandProfile?
  assets             Asset[]
  contentCalendars   ContentCalendar[]
  aiGenerations      AIGeneration[]
  socialIntegrations SocialIntegration[]
  reviews            Review[]
}

model BrandProfile {
  id                String   @id @default(cuid())
  businessId        String   @unique
  tone              String
  targetAudience    String
  keywords          String[]
  avoidWords        String[]
  visualStyle       String   // visual style preset name
  visualStylePreset String?  @default("cozy_rustic") // cozy_rustic | modern_minimal | bold_vibrant | earthy_natural | luxury_dark | custom
  customStylePrompt String?
  contentStrategy   String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id])
}

model Asset {
  id         String   @id @default(cuid())
  businessId String
  orgId      String?  // Clerk org ID for multi-tenant scoping
  type       String   // logo | product | lifestyle | background
  name       String   @default("")
  url        String
  tags       String[]
  useCount   Int      @default(0)
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@index([orgId])
}

model ContentCalendar {
  id          String   @id @default(cuid())
  businessId  String
  date        DateTime
  platform    String
  contentType String
  caption     String
  hashtags    String[]
  imageUrl    String?
  videoUrl    String?
  status      String   @default("draft") // draft | approved | published
  createdAt   DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])
}

model AIGeneration {
  id         String   @id @default(cuid())
  businessId String
  prompt     String
  model      String
  tokensUsed Int
  cost       Float
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])
}

model Subscription {
  id               String   @id @default(cuid())
  userId           String
  plan             String // free | pro | enterprise
  status           String // active | canceled | past_due
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model SocialIntegration {
  id           String    @id @default(cuid())
  businessId   String
  provider     String // e.g., "facebook", "instagram"
  providerId   String // Page ID or IG Account ID
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  profileName  String?
  profileUrl   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id])
}

model Review {
  id           String   @id @default(cuid())
  businessId   String
  provider     String // "google" | "facebook"
  externalId   String // Unique ID of the review from Google/Meta APIs
  authorName   String
  authorAvatar String?
  rating       Int // Star value: 1 to 5
  text         String   @db.Text
  publishDate  DateTime
  status       String   @default("unanswered") // "unanswered" | "replied" | "flagged"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  response ReviewResponse?

  @@unique([provider, externalId])
  @@index([businessId])
}

model ReviewResponse {
  id          String   @id @default(cuid())
  reviewId    String   @unique
  text        String   @db.Text
  status      String   @default("draft") // "draft" | "submitted" | "failed"
  generatedBy String   @default("ai") // "ai" | "manual"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}
